# Copy this file to .env for local testing with `node --env-file=.env dist/index.js`.
# For actual use with Claude, these go in the MCP server's "env" block in your
# Claude config instead (see README.md) — the .env file itself is never read by Claude.

BUGSINK_BASE_URL=https://bugsink.example.com
BUGSINK_TOKEN=your-bugsink-api-token-here

# Optional shared-secret gate on the /mcp endpoint. When set, callers must
# send `Authorization: Bearer <this-value>`. When unset, /mcp is open — fine
# for local dev, NOT fine for a public URL.
# Generate one with: openssl rand -hex 32
# MCP_AUTH_TOKEN=
